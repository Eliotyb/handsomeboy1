{"info": {"_postman_id": "groupon-seckill-api", "name": "社团秒杀系统 - 全量API接口测试", "description": "包含认证、用户、商品、秒杀、购物车、订单、物流、售后、评价、优惠券等全部接口的Postman测试集合\n\n## 使用说明\n1. 先执行「1.登录获取Token」接口，复制返回的token值\n2. 点击右上角「Eye」图标 → Variables → 将token粘贴到 `access_token` 变量中\n3. 后续需要认证的接口会自动携带Token\n\n## 基础信息\n- Base URL: http://localhost:8080\n- 认证方式: Bearer Token (Header: Authorization: Bearer {{access_token}})\n- 默认账号: admin / admin", "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"}, "variable": [{"key": "base_url", "value": "http://localhost:8080", "type": "string"}, {"key": "access_token", "value": "", "type": "string"}], "item": [{"name": "🔐 1. 认证模块 (Auth)", "item": [{"name": "用户登录", "event": [{"listen": "test", "script": {"exec": ["var jsonData = pm.response.json();", "if (jsonData.code === 200 && jsonData.data) {", "    pm.collectionVariables.set('access_token', jsonData.data.token);", "    pm.test('✅ 登录成功, Token已保存');", "} else {", "    pm.test('❌ 登录失败: ' + (jsonData.message || '未知错误'));", "}"]}}], "request": {"method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin\"\n}"}, "url": {"raw": "{{base_url}}/api/auth/login", "host": ["{{base_url}}"], "path": ["api", "auth", "login"]}}, "response": []}, {"name": "管理员登录", "request": {"method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin\"\n}"}, "url": {"raw": "{{base_url}}/api/auth/admin/login", "host": ["{{base_url}}"], "path": ["api", "auth", "admin", "login"]}}, "response": []}, {"name": "用户注册", "request": {"method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\n  \"username\": \"testuser001\",\n  \"password\": \"123456\",\n  \"name\": \"测试用户\",\n  \"phone\": \"13800138001\",\n  \"address\": \"北京市海淀区\"\n}"}, "url": {"raw": "{{base_url}}/api/auth/register", "host": ["{{base_url}}"], "path": ["api", "auth", "register"]}}, "response": []}, {"name": "退出登录", "request": {"method": "POST", "header": [{"key": "Authorization", "value": "Bearer {{access_token}}", "type": "text"}], "url": {"raw": "{{base_url}}/api/auth/logout", "host": ["{{base_url}}"], "path": ["api", "auth", "logout"]}}, "response": []}]}, {"name": "👤 2. 用户模块 (User)", "item": [{"name": "获取所有用户列表", "request": {"method": "GET", "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}], "url": {"raw": "{{base_url}}/api/users", "host": ["{{base_url}}"], "path": ["api", "users"]}}}, {"name": "根据ID查询用户", "request": {"method": "GET", "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}], "url": {"raw": "{{base_url}}/api/users/1", "host": ["{{base_url}}"], "path": ["api", "users", "1"]}}}, {"name": "创建用户(注册)", "request": {"method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{access_token}}"}], "body": {"mode": "raw", "raw": "{\n  \"username\": \"newuser002\",\n  \"password\": \"123456\",\n  \"name\": \"新用户\",\n  \"phone\": \"13900139002\",\n  \"address\": \"上海市浦东新区\",\n  \"role\": \"user\"\n}"}, "url": {"raw": "{{base_url}}/api/users", "host": ["{{base_url}}"], "path": ["api", "users"]}}}, {"name": "更新用户信息", "request": {"method": "PUT", "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{access_token}}"}], "body": {"mode": "raw", "raw": "{\n  \"id\": 2,\n  \"username\": \"zhangsan\",\n  \"name\": \"张三\",\n  \"phone\": \"13800138002\",\n  \"address\": \"广州市天河区\",\n  \"role\": \"user\"\n}"}, "url": {"raw": "{{base_url}}/api/users/2", "host": ["{{base_url}}"], "path": ["api", "users", "2"]}}}, {"name": "删除用户", "request": {"method": "DELETE", "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}], "url": {"raw": "{{base_url}}/api/users/{{userId}}", "host": ["{{base_url}}"], "path": ["api", "users", "{{userId}}"]}}}]}