{"info": {"_postman_id": "groupon-seckill-full-api", "name": "🚀 社团秒杀系统 - 全量API接口测试集合", "description": "# 社团团购秒杀后台管理系统 - Postman API测试集合\n\n## 📋 使用步骤\n1. 点击右上角 **眼睛图标** → **Edit** → 添加变量: `base_url`=http://localhost:8080, `access_token`=(留空)\n2. 先执行 **「1.1 用户登录」** → Token自动保存到环境变量\n3. 后续接口自动携带Token\n\n## 🔧 基础信息\n- Base URL: http://localhost:8080\n- 认证: Bearer Token (Header: Authorization: Bearer {{access_token}})\n- 管理员: admin / admin", "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"}, "variable": [{"key": "base_url", "value": "http://localhost:8080", "type": "string"}, {"key": "access_token", "value": "", "type": "string"}], "item": [
  {"name": "🔐 1.认证模块", "item": [
    {"name": "1.1 用户登录⭐(自动获取Token)", "event": [{"listen":"test","script":{"exec":["var d=pm.response.json();if(d.code==200&&d.data&&d.data.token){pm.collectionVariables.set('access_token',d.data.token);pm.test('✅ Token已保存');}else{pm.test('❌ '+d.message);}"]}}], "request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\"username\":\"admin\",\"password\":\"admin\"}"},"url":{"raw":"{{base_url}}/api/auth/login"}}},
    {"name": "1.2 管理员登录", "request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\"username\":\"admin\",\"password\":\"admin\"}"},"url":{"raw":"{{base_url}}/api/auth/admin/login"}}},
    {"name": "1.3 注册新用户", "request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\"username\":\"test_"+Date.now(),\"password\":\"123456\",\"name\":\"测试用户\",\"phone\":\"13800138001\",\"address\":\"北京\"}"},"url":{"raw":"{{base_url}}/api/auth/register"}}},
    {"name": "1.4 退出登录", "request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{access_token}}"}],"url":{"raw":"{{base_url}}/api/auth/logout"}}}
  ]},
  {"name": "👤 2.用户模块", "item": [
    {"name": "2.1 获取所有用户", "request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{access_token}}"}],"url":{"raw":"{{base_url}}/api/users"}}},
    {"name": "2.2 查询用户详情", "request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{access_token}}"}],"url":{"raw":"{{base_url}}/api/users/1"}}},
    {"name": "2.3 创建用户", "request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{access_token}}"}],"body":{"mode":"raw","raw":"{\"username\":\"newuser"+Date.now(),\"password\":\"123456\",\"name\":\"新用户\",\"phone\":\"13900139002\",\"address\":\"上海\",\"role\":\"user\"}"},"url":{"raw":"{{base_url}}/api/users"}}},
    {"name": "2.4 更新用户", "request":{"method":"PUT","header":[{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{access_token}}"}],"body":{"mode":"raw","raw":"{\"id\":2,\"username\":\"zhangsan\",\"name\":\"张三(已更新)\",\"phone\":\"13800138002\",\"address\":\"广州天河区\",\"role\":\"user\"}"},"url":{"raw":"{{base_url}}/api/users/2"}}},
    {"name": "2.5 删除用户", "request":{"method":"DELETE","header":[{"key":"Authorization","value":"Bearer {{access_token}}"}],"url":{"raw":"{{base_url}}/api/users/{{userId}}"}}}
  ]},
  {"name": "📦 3.商品模块", "item": [
    {"name": "3.1 获取所有商品", "request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{access_token}}"}],"url":{"raw":"{{base_url}}/api/products"}}},
    {"name": "3.2 商品详情", "request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{access_token}}"}],"url":{"raw":"{{base_url}}/api/products/1"}}},
    {"name": "3.3 新增商品", "request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{access_token}}"}],"body":{"mode":"raw","raw":"{\"name\":\"测试商品-"+Date.now(),\"description\":\"Postman测试商品描述\",\"price\":99.9,\"stock\":100,\"image\":\"https://example.com/img.jpg\",\"status\":1}"},"url":{"raw":"{{base_url}}/api/products"}}},
    {"name": "3.4 更新商品", "request":{"method":"PUT","header":[{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{access_token}}"}],"body":{"mode":"raw","raw":"{\"id\":1,\"name\":\"蓝牙耳机Pro(已编辑)\",\"description\":\"高品质无线耳机\",\"price\":299.00,\"stock\":200,\"image\":\"https://example.com/img.jpg\",\"status\":1}"},"url":{"raw":"{{base_url}}/api/products/1"}}},
    {"name": "3.5 删除商品", "request":{"method":"DELETE","header":[{"key":"Authorization","value":"Bearer {{access_token}}"}],"url":{"raw":"{{base_url}}/api/products/{{productId}}"}}}
  ]},
  {"name": "⚡ 4.秒杀活动", "item": [
    {"name": "4.1 获取所有活动", "request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{access_token}}"}],"url":{"raw":"{{base_url}}/api/seckill-activities"}}},
    {"name": "4.2 活动详情", "request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{access_token}}"}],"url":{"raw":"{{base_url}}/api/seckill-activities/1"}}},
    {"name": "4.3 创建活动", "request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{access_token}}"}],"body":{"mode":"raw","raw":"{\"name\":\"盛夏狂欢数码周-"+Date.now(),\"startTime\":\"2026-05-01 10:00:00\",\"endTime\":\"2026-05-03 23:59:59\",\"status\":1}"},"url":{"raw":"{{base_url}}/api/seckill-activities"}}},
    {"name": "4.4 更新活动", "request":{"method":"PUT","header":[{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{access_token}}"}],"body":{"mode":"raw","raw":"{\"id\":1,\"name\":\"九月开学季礼包(已编辑)\",\"startTime\":\"2026-09-01 00:00:00\",\"endTime\":\"2026-09-30 23:59:59\",\"status\":1}"},"url":{"raw":"{{base_url}}/api/seckill-activities/1"}}},
    {"name": "4.5 删除活动", "request":{"method":"DELETE","header":[{"key":"Authorization","value":"Bearer {{access_token}}"}],"url":{"raw":"{{base_url}}/api/seckill-activities/{{activityId}}"}}}
  ]},
  {"name": "🎯 5.秒杀商品", "item": [
    {"name": "5.1 获取所有秒杀商品", "request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{access_token}}"}],"url":{"raw":"{{base_url}}/api/seckill-products"}}},
    {"name": "5.2 秒杀商品详情", "request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{access_token}}"}],"url":{"raw":"{{base_url}}/api/seckill-products/1"}}},
    {"name": "5.3 添加秒杀商品", "request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{access_token}}"}],"body":{"mode":"raw","raw":"{\"activityId\":1,\"productId\":1,\"seckillPrice\":99.00,\"seckillStock\":50,\"soldCount\":0}"},"url":{"raw":"{{base_url}}/api/seckill-products"}}},
    {"name": "5.4 更新秒杀商品", "request":{"method":"PUT","header":[{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{access_token}}"}],"body":{"mode":"raw","raw":"{\"id\":1,\"activityId\":1,\"productId\":1,\"seckillPrice\":79.90,\"seckillStock\":100,\"soldCount\":25}"},"url":{"raw":"{{base_url}}/api/seckill-products/1"}}},
    {"name": "5.5 删除秒杀商品", "request":{"method":"DELETE","header":[{"key":"Authorization","value":"Bearer {{access_token}}"}],"url":{"raw":"{{base_url}}/api/seckill-products/{{spId}}"}}}
  ]},
  {"name": "🛒 6.购物车模块", "item": [
    {"name": "6.1 查看购物车", "request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{access_token}}"}],"url":{"raw":"{{base_url}}/api/cart"}}},
    {"name": "6.2 加入购物车", "request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{access_token}}"}],"body":{"mode":"raw","raw":"{\"productId\":1,\"quantity\":2}"},"url":{"raw":"{{base_url}}/api/cart"}}},
    {"name": "6.3 修改数量", "request":{"method":"PUT","header":[{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{access_token}}"}],"body":{"mode":"raw","raw":"{\"quantity\":5}"},"url":{"raw":"{{base_url}}/api/cart/{{cartItemId}}"}}},
    {"name": "6.4 删除购物车项", "request":{"method":"DELETE","header":[{"key":"Authorization","value":"Bearer {{access_token}}"}],"url":{"raw":"{{base_url}}/api/cart/{{cartItemId}}"}}},
    {"name": "6.5 清空购物车", "request":{"method":"DELETE","header":[{"key":"Authorization","value":"Bearer {{access_token}}"}],"url":{"raw":"{{base_url}}/api/cart/clear"}}}
  ]},
  {"name": "🎫 7.优惠券模块", "item": [
    {"name": "7.1 我的优惠券", "request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{access_token}}"}],"url":{"raw":"{{base_url}}/api/coupons/user"}}},
    {"name": "7.2 可领取优惠券列表", "request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{access_token}}"}],"url":{"raw":"{{base_url}}/api/coupons/available"}}},
    {"name": "7.3 领取优惠券", "request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{access_token}}"}],"url":{"raw":"{{base_url}}/api/coupons/{{couponId}}/receive"}}},
    {"name": "7.4 使用优惠券", "request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{access_token}}"}],"body":{"mode":"raw","raw":"{\"orderId\":1}"},"url":{"raw":"{{base_url}}/api/coupons/{{couponId}}/use"}}}
  ]},
  {"name": "📋 8.订单模块(核心)", "item": [
    {"name": "8.1 所有订单列表", "request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{access_token}}"}],"url":{"raw":"{{base_url}}/api/orders"}}},
    {"name": "8.2 我的订单", "request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{access_token}}"}],"url":{"raw":"{{base_url}}/api/orders/user/my-orders"}}},
    {"name": "8.3 订单详情", "request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{access_token}}"}],"url":{"raw":"{{base_url}}/api/orders/{{orderId}}"}}},
    {"name": "8.4 创建普通订单(从购物车)", "event": [{"listen":"test","script":{"exec":["var d=pm.response.json();pm.test(d.code===200?'✅ 订单创建成功: '+d.data.orderNo:'❌ '+d.message);"]}}], "request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{access_token}}"}],"body":{"mode":"raw","raw":"{}"},"url":{"raw":"{{base_url}}/api/orders/create"}}},
    {"name": "8.5 秒杀下单", "event": [{"listen":"test","script":{"exec":["var d=pm.response.json();pm.test(d.code===200?'✅ 秒杀订单创建成功: '+d.data.orderNo:'❌ '+d.message);"]}}], "request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{access_token}}"}],"body":{"mode":"raw","raw":"{\"productId\":1,\"price\":99.00,\"quantity\":1,\"receiverName\":\"张三\",\"receiverPhone\":\"138****9012\",\"receiverAddress\":\"上海市浦东新区某某路888号A1座1502室\",\"payMethod\":\"wechat\"}"},"url":{"raw":"{{base_url}}/api/orders/seckill"}}},
    {"name": "8.6 确认付款", "request":{"method":"PUT","header":[{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{access_token}}"}],"body":{"mode":"raw","raw":"{\"payMethod\":\"wechat\"}"},"url":{"raw":"{{base_url}}/api/orders/{{orderId}}/pay"}}},
    {"name": "8.7 发货(填物流)", "request":{"method":"PUT","header":[{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{access_token}}"}],"body":{"mode":"raw","raw":"{\"logisticsCompany\":\"顺丰速运\",\"logisticsNo\":\"SF1234567890123\"}"},"url":{"raw":"{{base_url}}/api/orders/{{orderId}}/ship"}}},
    {"name": "8.8 确认收货", "request":{"method":"PUT","header":[{"key":"Authorization","value":"Bearer {{access_token}}"}],"url":{"raw":"{{base_url}}/api/orders/{{orderId}}/receive"}}},
    {"name": "8.9 取消订单", "request":{"method":"PUT","header":[{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{access_token}}"}],"body":{"mode":"raw","raw":"{\"reason\":\"用户主动取消\"}"},"url":{"raw":"{{base_url}}/api/orders/{{orderId}}/cancel"}}},
    {"name": "8.10 按状态查订单(0待付/1待发/2待收/3完成/4取消)", "request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{access_token}}"}],"url":{"raw":"{{base_url}}/api/orders/user/status/{{orderStatus}"}}}},
    {"name": "8.11 订单统计", "request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{access_token}}"}],"url":{"raw":"{{base_url}}/api/orders/stats"}}},
    {"name": "8.12 更新订单(全字段)", "request":{"method":"PUT","header":[{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{access_token}}"}],"body":{"mode":"raw","raw":"{\"id\":1,\"orderNo\":\"ORD-xxx\",\"userId\":1,\"productId\":1,\"price\":99.0,\"quantity\":1,\"totalPrice\":99.0,\"payMethod\":\"wechat\",\"status\":1,\"receiverName\":\"张三\",\"receiverPhone\":\"138****9012\",\"receiverAddress\":\"上海市浦东新区\",\"logisticsCompany\":\"顺丰速运\",\"logisticsNo\":\"SF123456789\"}"},"url":{"raw":"{{base_url}}/api/orders/1"}}},
    {"name": "8.13 删除订单", "request":{"method":"DELETE","header":[{"key":"Authorization","value":"Bearer {{access_token}}"}],"url":{"raw":"{{base_url}}/api/orders/{{orderId}}}"}}
  ]},
  {"name": "🚚 9.物流模块", "item": [
    {"name": "9.1 查询订单物流记录", "request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{access_token}}"}],"url":{"raw":"{{base_url}}/api/logistics/order/{{orderId}}"}}},
    {"name": "9.2 最新物流状态", "request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{access_token}}"}],"url":{"raw":"{{base_url}}/api/logistics/order/{{orderId}}/latest"}}},
    {"name": "9.3 创建物流记录", "request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{access_token}}"}],"body":{"mode":"raw","raw":"{\"orderId\":1,\"logisticsCompany\":\"顺丰速运\",\"logisticsNo\":\"SF987654321098\",\"status\":2,\"currentLocation\":\"上海市转运中心已发出\",\"remark\":\"正常运输中\"}"},"url":{"raw":"{{base_url}}/api/logistics"}}},
    {"name": "9.4 更新物流状态", "request":{"method":"PUT","header":[{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{access_token}}"}],"body":{"mode":"raw","raw":"{\"status\":3,\"currentLocation\":\"正在派送中\"}"},"url":{"raw":"{{base_url}}/api/logistics/{{logisticsId}}/status"}}}
  ]},
  {"name": "↩️ 10.售后退款", "item": [
    {"name": "10.1 申请退款", "request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{access_token}}"}],"body":{"mode":"raw","raw":"{\"orderId\":5,\"refundType\":1,\"reason\":\"不想要了\",\"description\":\"拍错了颜色不对\",\"amount\":299.00}"},"url":{"raw":"{{base_url}}/api/refunds/apply"}}},
    {"name": "10.2 我的退款记录", "request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{access_token}}"}],"url":{"raw":"{{base_url}}/api/refunds/my"}}},
    {"name": "10.3 全部退款列表(管理端)", "request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{access_token}}"}],"url":{"raw":"{{base_url}}/api/refunds/list"}}},
    {"name": "10.4 按状态筛选退款", "request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{access_token}}"}],"url":{"raw":"{{base_url}}/api/refunds/list/status/{{refundStatus}}"}}}},
    {"name": "10.5 审核退款(通过)", "request":{"method":"PUT","header":[{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{access_token}}"}],"body":{"mode":"raw","raw":"{\"auditUserId\":1,\"status\":3,\"remark\":\"审核通过，同意退款\"}"},"url":{"raw":"{{base_url}}/api/refunds/{{refundId}}/audit"}}},
    {"name": "10.6 审核退款(拒绝)", "request":{"method":"PUT","header":[{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{access_token}}"}],"body":{"mode":"raw","raw":"{\"auditUserId\":1,\"status\":4,\"remark\":\"不符合退款条件\",\"rejectReason\":\"商品无质量问题\"}"},"url":{"raw":"{{base_url}}/api/refunds/{{refundId}}/audit"}}}
  ]},
  {"name": "⭐ 11.评价模块", "item": [
    {"name": "11.1 提交评价", "request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{access_token}}"}],"body":{"mode":"raw","raw":"{\"orderId\":3,\"productId\":1,\"rating\":5,\"content\":\"非常满意！质量好，发货快，下次还来！性价比超高！\",\"isAnonymous\":0}"},"url":{"raw":"{{base_url}}/api/reviews"}}},
    {"name": "11.2 商品评价列表", "request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{access_token}}"}],"url":{"raw":"{{base_url}}/api/reviews/product/{{productId}}"}}}},
    {"name": "11.3 商品平均评分", "request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{access_token}}"}],"url":{"raw":"{{base_url}}/api/reviews/product/{{productId}}/avg-rating"}}},
    {"name": "11.4 我的评价", "request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{access_token}}"}],"url":{"raw":"{{base_url}}/api/reviews/my"}}},
    {"name": "11.5 待评价订单", "request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{access_token}}"}],"url":{"raw":"{{base_url}}/api/reviews/pending/my"}}},
    {"name": "11.6 全部评价列表(管理端)", "request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{access_token}}"}],"url":{"raw":"{{base_url}}/api/reviews/list"}}},
    {"name": "11.7 商家回复评价", "request":{"method":"PUT","header":[{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{access_token}}"}],"body":{"mode":"raw","raw":"{\"replyContent\":\"感谢您的支持！我们会继续努力为您提供更好的产品和服务~\"}"},"url":{"raw":"{{base_url}}/api/reviews/{{reviewId}}/reply"}}}
